{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "outDir": "src/frontend/dist",
    "rootDir": "src/frontend",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": ["src/frontend/**/*.ts"],
  "exclude": ["node_modules"]
}
